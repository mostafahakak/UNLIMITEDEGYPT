# Egypt Accept base URL ([Paymob Intention APIs](https://developers.paymob.com/paymob-docs/developers/intention-apis/create-intention))
PAYMOB_BASE_URL=https://accept.paymob.com

# Settings → Account Info (test vs live toggle). Auth header format: Authorization: Token <SECRET>
PAYMOB_SECRET_KEY=

# Unified checkout redirect query param `publicKey` — same dashboard screen as secret
PAYMOB_PUBLIC_KEY=

# Developers → Payment Integrations — comma-separated numeric IDs matching `PAYMOB_SECRET_KEY` mode (test/live)
PAYMOB_INTEGRATION_IDS=

# Amounts must match Integration currency ([Egypt docs](https://developers.paymob.com/egypt/getting-started-egypt)): use piasters/minor units (integer cents)
PAYMOB_QUICK_CLARITY_CENTS=
PAYMOB_BUSINESS_ADVISORY_CENTS=
PAYMOB_MONTHLY_MENTORSHIP_CENTS=

# Usually EGP for Egypt dashboards
PAYMOB_CURRENCY=EGP

# Transaction callbacks — regenerate if leaked ([HMAC callbacks](https://developers.paymob.com/paymob-docs/developers/webhook-callbacks-and-hmac))
PAYMOB_HMAC_SECRET=

# Paymob transaction callback — defaults in server.js to https://unlimitedegypt.onrender.com/paymob/webhook; set to override (e.g. webhook.site for local tests)
# PAYMOB_NOTIFICATION_URL=https://unlimitedegypt.onrender.com/paymob/webhook

# Customer browser return ([Unified checkout](https://github.com/PaymobAccept/API-Postman-Collections)): override default from static site `/payment/return`
# PAYMOB_REDIRECT_URL=https://www.example.com/payment/return

# CORS: browser `Origin` must match. One host, or comma list. Apex and `www.` are auto-added for each host.
PAYMOB_CORS_ORIGIN=https://koriemconsulting.com
# PAYMOB_CORS_ORIGINS=https://koriemconsulting.com,https://koriemconsulting.web.app

# After Paymob checkout, if PAYMOB_REDIRECT_URL unset — use this site's origin (match your live domain)
# PAYMOB_SITE_ORIGIN=https://koriemconsulting.com

PORT=8787

# Optional: if callbacks differ from automated flatten, set explicit field order (comma-separated) from Paymob HMAC docs
# PAYMOB_HMAC_MODE=experimental_order
# PAYMOB_HMAC_FIELDS=id,amount_cents,...

# Danger: local only — disables HMAC check (callbacks are trusted)
# PAYMOB_SKIP_HMAC_VERIFY=true
